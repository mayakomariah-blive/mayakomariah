    <?php
        $sekarang = getdate(); // Mengambil waktu lokal [cite: 72, 88]
        $bulan = $sekarang['month']; // Nama bulan tekstual [cite: 85, 88]
        $hari = $sekarang['mday']; // Hari dalam bulan [cite: 78, 88]
        $tahun = $sekarang['year']; // Tahun numeris [cite: 82, 88]
        $jam = $sekarang['hours']; // Jam dalam format 24 jam [cite: 79, 89]

        // Logika Kondisional untuk Ucapan Selamat [cite: 89, 90]
        if ($jam <= 11) {
            echo "Selamat Pagi";
        } elseif ($jam > 11 and $jam <= 15) {
            echo "Selamat Siang";
        } elseif ($jam > 15 and $jam <= 18) {
            echo "Selamat Sore";
        } elseif ($jam > 18) {
            echo "Selamat Malam";
        }
    ?>
    </h1>
    <h2>Selamat datang</h2>
    <h3>Sekarang adalah tanggal <?php echo "$hari $bulan $tahun"; ?></h3> </center>
